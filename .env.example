# Configuration de l'environnement - APPLICATION DE GESTION DE CONTACTS
# Copiez ce fichier en .env et modifiez les valeurs si nécessaire

# Port du serveur
PORT=3000

# Mode : 'development' ou 'production'
NODE_ENV=development

# Chemin vers la base de données SQLite (optionnel, valeur par défaut dans le code)
# DATABASE_PATH=./data/contacts.db
